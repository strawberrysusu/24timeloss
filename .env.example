cDB_URL=jdbc:mysql://localhost:3306/newspick?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=YOUR_PASSWORD

JWT_SECRET=YOUR_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG
JWT_ACCESS_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_DAYS=7

# Google OAuth2 (Google Cloud Console에서 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Naver OAuth2 Login (https://developers.naver.com → "네이버 로그인" 애플리케이션 등록)
# Callback URL: {도메인}/login/oauth2/code/naver
# 아래 NAVER_CLIENT_ID(검색 API)와 다른 별개 애플리케이션입니다.
NAVER_LOGIN_CLIENT_ID=
NAVER_LOGIN_CLIENT_SECRET=

# 네이버 뉴스 검색 API (https://developers.naver.com → 애플리케이션 등록)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_NEWS_COLLECT_ENABLED=false
# NAVER_NEWS_COLLECT_SIZE=5  ← 카테고리당 수집 기사 수 (기본 5)

# 자동수집 기사 보관 기간 (일). 0이면 정리 비활성화.
# 매일 새벽 3시에 ARTICLE_RETENTION_DAYS일 지난 미저장 자동수집 기사를 삭제한다.
# 사용자 직접 작성 / 누군가 저장한 기사는 영구 보존.
ARTICLE_RETENTION_DAYS=0

AI_API_KEY=
AI_MODEL=meta/llama-3.3-70b-instruct
AI_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
AI_TIMEOUT=30
AI_MOCK_ENABLED=false

# Public host for prod nginx / HTTPS (example: 43.202.121.142.nip.io)
APP_HOST=your-domain.example

# Docker image (운영 서버의 .env에 ECR URI 설정)
# APP_IMAGE=123456789.dkr.ecr.ap-northeast-2.amazonaws.com/newspick:latest
